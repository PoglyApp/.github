    "data": "{\"widgetName\":\"YouTube Player\",\"widgetWidth\":560,\"widgetHeight\":315,\"headerTag\":\"\",\"bodyTag\":\"<p id=\\\"error\\\"></p>\\n<div class=\\\"container\\\" id=\\\"player\\\"></div>\",\"styleTag\":\".container{\\n  width: 100vw;\\n  height:100vh;\\n}\\n\\nbody {\\n  margin: 0;\\n}\",\"scriptTag\":\"let tag = document.createElement('script');\\ntag.src = 'https://www.youtube.com/iframe_api';\\n\\nlet firstScriptTag = document.getElementsByTagName('script')[0];\\nfirstScriptTag.parentNode.insertBefore(tag, firstScriptTag);\\n\\nlet player;\\nlet controls = 0;\\nlet shouldBePlaying = false;\\nlet volume = {volume};\\nlet index = '{playlist_start_video}' ? parseInt('{playlist_start_video}', 10) : 0;\\nlet subtitles = {subtitles} ? 1 : 0;\\nlet shuffled = false;\\nlet reshuffled = {reshuffle};\\nlet loop = {loop};\\nlet intervalID = null;\\nlet start_time = '{start_time}' ? parseInt('{start_time}', 10) : 0;\\nlet end_time = '{end_time}' ? parseInt('{end_time}', 10) : 0;\\nlet playlistRefresh = false;\\nlet current_playlist = [];\\nlet current_index = 0;\\nlet current_time = 0;\\n\\nlet rawInput = '{video_id}';\\nlet parsed = parseYouTubeInput(rawInput);\\n\\nfunction parseYouTubeInput(input) {\\n\\n    const result = {\\n        videoId: null,\\n        playlistId: null,\\n        startTime: null,\\n        endTime: null,\\n        isPlaylist: false,\\n        playlistIndex: null\\n    };\\n\\n    // Raw playlist ID (starts with 'PL', 'UU', 'RD', 'OL', etc.)\\n    if (/^(PL|UU|RD|OL)[a-zA-Z0-9_-]+$/.test(input)) {\\n        result.playlistId = input;\\n        result.isPlaylist = true;\\n        return result;\\n    }\\n\\n    // Raw video ID (11 characters)\\n    if (/^[a-zA-Z0-9_-]{11}$/.test(input)) {\\n        result.videoId = input;\\n        return result;\\n    }\\n\\n    // Try parsing as URL\\n    try {\\n        const parsed = new URL(input);\\n        const pathname = parsed.pathname;\\n        const searchParams = parsed.searchParams;\\n\\n        // Video ID extraction\\n        if (parsed.hostname.includes('youtu.be')) {\\n            result.videoId = pathname.slice(1);\\n        } else if (pathname.startsWith('/watch')) {\\n            result.videoId = searchParams.get('v');\\n        } else if (pathname.startsWith('/embed/')) {\\n            result.videoId = pathname.split('/embed/')[1].split(/[/?]/)[0];\\n        } else if (pathname.startsWith('/v/')) {\\n            result.videoId = pathname.split('/v/')[1].split(/[/?]/)[0];\\n        } else if (pathname.startsWith('/shorts/')) {\\n            result.videoId = pathname.split('/shorts/')[1].split(/[/?]/)[0];\\n        }\\n\\n        // Playlist ID\\n        if (searchParams.has('list')) {\\n            result.playlistId = searchParams.get('list');\\n            result.isPlaylist = true;\\n        }\\n\\n        // Playlist index\\n        if (searchParams.has('index')) {\\n            result.playlistIndex = parseInt(searchParams.get('index')) - 1;\\n            index = result.playlistIndex;\\n        }\\n\\n        // Start time\\n        if (searchParams.has('start')) {\\n            result.startTime = parseInt(searchParams.get('start'));\\n        } else if (searchParams.has('t')) {\\n            result.startTime = parseTimeParam(searchParams.get('t'));\\n        }\\n\\n        // End time\\n        if (searchParams.has('end')) {\\n            result.endTime = parseInt(searchParams.get('end'));\\n        }\\n\\n    } catch (e) {\\n        console.warn('Invalid YouTube input:', input);\\n    }\\n\\n    return result;\\n}\\n\\nfunction playerVars(video_index = index, startSeconds = start_time, endSeconds = end_time) {\\n    return parsed.isPlaylist ? {\\n        listType: 'playlist',\\n        list: parsed.playlistId,\\n        index: video_index || parsed.playlistIndex || 0,\\n        startSeconds: startSeconds || parsed.startTime || undefined\\n    } : {\\n        videoId: parsed.videoId,\\n        startSeconds: startSeconds || parsed.startTime || undefined,\\n        endSeconds: endSeconds || parsed.endTime || undefined\\n    };\\n}\\n\\nfunction noInput(input) {\\n    if (!input) {\\n        showPlayer(false);\\n        showError(true);\\n        document.getElementById('error').innerText = 'Error: Please Provide Valid Link'\\n        return true;\\n    }\\n    else {\\n        showPlayer(true);\\n        showError(false);\\n        return false;\\n    }\\n}\\n\\n// Converts '1m30s' or '90' to seconds\\nfunction parseTimeParam(t) {\\n    if (/^\\\\d+$/.test(t)) return parseInt(t);\\n    const match = t.match(/(?:(\\\\d+)h)?(?:(\\\\d+)m)?(?:(\\\\d+)s)?/);\\n    if (!match) return null;\\n    const hours = parseInt(match[1]) || 0;\\n    const minutes = parseInt(match[2]) || 0;\\n    const seconds = parseInt(match[3]) || 0;\\n    return hours * 3600 + minutes * 60 + seconds;\\n}\\n\\nfunction onYouTubeIframeAPIReady() {\\n    controls = 0;\\n\\n    player = new YT.Player('player', {\\n        height: '100%',\\n        width: '100%',\\n        playerVars:  {\\n            controls: controls,\\n            playsinline: 1,\\n            cc_load_policy: 1\\n        },\\n        events: {\\n            'onReady': onReady,\\n            'onError': onPlayerError,\\n            'onStateChange': onStateChange\\n        }\\n    });\\n}\\n\\nfunction onReady(event) {\\n    noInput(rawInput);\\n\\n    event.target.setVolume(volume);\\n\\n    if (parsed.isPlaylist) {\\n        if ({autoplay}) {\\n            shouldBePlaying = true;\\n            player.loadPlaylist(playerVars());\\n        } else {\\n            player.cuePlaylist(playerVars());\\n        }\\n        playlistLoop();\\n    } else {\\n        if ({autoplay}) {\\n            shouldBePlaying = true;\\n            player.loadVideoById(playerVars());\\n        } else {\\n            player.cueVideoById(playerVars());\\n        }\\n        singleVideoLoop();\\n    }\\n}\\n\\nfunction onPlayerError(event) {\\n    switch (event.data) {\\n        case 2:\\n            videoError('Error: Invalid parameter');\\n            break;\\n        case 100:\\n            videoError('Error: Video not found or has been removed');\\n            break;\\n        case 101:\\n        case 150:\\n            videoError('Error: Embedding disabled for this video');\\n            break;\\n        default:\\n            videoError();\\n    }\\n    noInput(rawInput);\\n}\\n\\nfunction onStateChange(event) {\\n\\n    if (event.data === YT.PlayerState.CUED || event.data === YT.PlayerState.PLAYING) {\\n        captions();\\n        parsed.isPlaylist ? playlistLoop() : singleVideoLoop();\\n    }\\n\\n    if (event.data === -1 && playlistRefresh) {\\n        refreshPlaylist();\\n    }\\n}\\n\\nfunction showPlayer(show) {\\n    document.getElementById('player').style.display = show ? 'unset' : 'none';\\n}\\n\\nfunction showError(show) {\\n    document.getElementById('error').style.display = show ? 'unset' : 'none';\\n}\\n\\nfunction onLiveVariableUpdate(name, value) {\\n    // name: variable name, value: new value (always a string)\\n    switch (name) {\\n        case 'video_id': {\\n\\n            if (noInput(value)){\\n                player.stopVideo();\\n                break;\\n            }\\n\\n            player.stopVideo();\\n\\n            parsed = parseYouTubeInput(value);\\n            intervalID !== null && clearInterval(intervalID);\\n            if (parsed.isPlaylist) {\\n                shouldBePlaying ? player.loadPlaylist(playerVars(parsed.playlistIndex)) : player.cuePlaylist(playerVars(parsed.playlistIndex));\\n            } else {\\n                shouldBePlaying ? player.loadVideoById(playerVars()) : player.cueVideoById(playerVars());\\n            }\\n            player.setVolume(volume);\\n            break;\\n        }\\n        case 'volume': {\\n            if (player && typeof player.setVolume === 'function') {\\n                volume = Math.min(100, Math.max(0, parseInt(value, 10)));\\n                player.setVolume(volume);\\n            }\\n            break;\\n        }\\n        case 'play/pause': {\\n            if (player && typeof player.getPlayerState === 'function') {\\n                if (player.getPlayerState() !==  1) {\\n                    shouldBePlaying = true;\\n                    player.playVideo();\\n                } else {\\n                    shouldBePlaying = false;\\n                    player.pauseVideo();\\n                }\\n            }\\n            break;\\n        }\\n        case 'playlist_start_video': {\\n            if (player && typeof player.playVideoAt === 'function') {\\n                index = Math.max(0, value ? parseInt(value, 10) : parsed.playlistIndex);\\n                player.playVideoAt(index);\\n                if (!shouldBePlaying) player.pauseVideo();\\n            }\\n            break;\\n        }\\n        case 'playlist_next': {\\n            if (player && typeof player.nextVideo === 'function') {\\n                player.nextVideo();\\n                if (!shouldBePlaying) player.pauseVideo();\\n            }\\n            break;\\n        }\\n        case 'playlist_previous': {\\n            if (player && typeof player.previousVideo === 'function') {\\n                player.previousVideo();\\n                if (!shouldBePlaying) player.pauseVideo();\\n            }\\n            break;\\n        }\\n        case 'playback_speed': {\\n            let speed = parseFloat(value)\\n            // noinspection EqualityComparisonWithCoercionJS\\n            if (player && typeof player.getPlaybackRate === 'function' && player.getPlaybackRate() != speed) {\\n                player.setPlaybackRate(speed);\\n            }\\n            break;\\n        }\\n        case 'subtitles': {\\n            subtitles = subtitles ? 0 : 1;\\n            captions();\\n            break;\\n        }\\n        case 'shuffle': {\\n            if (parsed.isPlaylist) {\\n                if (reshuffled) {\\n                    player.setShuffle(true);\\n                    shuffled = true;\\n                    player.playVideoAt(0);\\n                }\\n                else {\\n                    player.setShuffle(!shuffled);\\n                    shuffled = !shuffled;\\n                    player.playVideoAt(shuffled ? 0 : index); // go to initial video if shuffled otherwise indexed\\n                }\\n                shouldBePlaying || player.pauseVideo(); // pause video if it shouldn't be playing\\n            }\\n            break;\\n        }\\n        case 'reshuffle': {\\n            reshuffled = value === 'true';\\n            break;\\n        }\\n        case 'loop': {\\n            loop = value === 'true';\\n            playlistLoop();\\n            singleVideoLoop();\\n            break;\\n        }\\n        case 'refresh_playlist': {\\n            if(parsed.isPlaylist) {\\n                current_playlist = player.getPlaylist();\\n                current_index = player.getPlaylistIndex();\\n                current_time = player.getCurrentTime();\\n\\n                player.loadPlaylist(playerVars(current_index, current_time));\\n                playlistRefresh = true;\\n            }\\n        }\\n    }\\n}\\n\\nfunction captions() {\\n    if (!subtitles) {\\n        player.setOption('captions', 'track', {});\\n    } else {\\n        player.setOption('captions', 'track', player.getOption('captions', 'track'));\\n    }\\n}\\n\\nfunction singleVideoLoop() {\\n    if (parsed.isPlaylist) {\\n        clearInterval(intervalID);\\n        intervalID = null;\\n        return;\\n    }\\n\\n    if (loop) {\\n        intervalID = setInterval(() => {\\n            player.getPlayerState() === YT.PlayerState.ENDED &&  player.seekTo(parsed.startTime || start_time)\\n        }, 1000);\\n    }\\n    else {\\n        clearInterval(intervalID);\\n        intervalID = null;\\n    }\\n}\\n\\nfunction playlistLoop() {\\n    parsed.isPlaylist && player.setLoop(loop);\\n}\\n\\nfunction refreshPlaylist() {\\n    const new_playlist = player.getPlaylist();\\n    let updated_list = mergeLists(current_playlist, new_playlist);\\n\\n    if (updated_list !== current_playlist) {\\n        player.stopVideo();\\n        let new_index = current_index;\\n\\n        [new_index, current_time] = findNearestPresentIndex(current_playlist, updated_list, current_index, current_time);\\n\\n        shouldBePlaying ? player.loadPlaylist(updated_list, new_index, current_time) : player.cuePlaylist(updated_list, new_index, current_time);\\n    }\\n    playlistRefresh = false;\\n}\\n\\nfunction mergeLists(oldList, newList) {\\n\\n    if (!shuffled) return newList;\\n\\n    const newSet = new Set(newList);\\n\\n    // Keep old items only if they still exist in newList, preserving old order\\n    const merged = oldList.filter(item => newSet.has(item));\\n\\n    // Append items from newList that weren't already in merged, preserving newList order\\n    const mergedSet = new Set(merged);\\n    for (const item of newList) {\\n        if (!mergedSet.has(item)) {\\n            merged.push(item);\\n            mergedSet.add(item);\\n        }\\n    }\\n\\n    return merged;\\n}\\n\\nfunction findNearestPresentIndex(oldArray, newArray, currentIndex, currentTime) {\\n    // Check with the starting index first\\n    if (currentIndex >= 0 && currentIndex < oldArray.length) {\\n        const newIndex = newArray.indexOf(oldArray[currentIndex]);\\n        if (newIndex !== -1) return [newIndex, currentTime];\\n    }\\n\\n    // Search forward, wrapping around to the start once the end is reached\\n    for (let offset = 1; offset < oldArray.length; offset++) {\\n        const i = (currentIndex + offset) % oldArray.length;\\n        const newIndex = newArray.indexOf(oldArray[i]);\\n        if (newIndex !== -1) return [newIndex, 0];\\n    }\\n\\n    // Nothing found at all, start from beginning of new array\\n    return [0, 0];\\n}\\n\\nfunction videoError(error_message = 'Error: unknown error occurred') {\\n    // Attempt to skip the broken video if it's in a playlist, otherwise show error\\n    if (parsed.isPlaylist) {\\n        const failedIndex = player.getPlaylistIndex();\\n        const nextIndex = failedIndex < 0 ? 1 : failedIndex + 1;\\n        shouldBePlaying ? player.loadPlaylist(playerVars(nextIndex)) : player.cuePlaylist(playerVars(nextIndex));\\n        console.warn(error_message, ' attempting to skip video');\\n    } else {\\n        showPlayer(false);\\n        showError(true);\\n        document.getElementById('error').innerText = error_message;\\n    }\\n}\",\"variables\":[{\"variableName\":\"start_time\",\"variableType\":1,\"variableValue\":\"\",\"variableLive\":false},{\"variableName\":\"end_time\",\"variableType\":1,\"variableValue\":\"\",\"variableLive\":false},{\"variableName\":\"autoplay\",\"variableType\":3,\"variableValue\":false,\"variableLive\":false},{\"variableName\":\"video_id\",\"variableType\":1,\"variableValue\":\"https://www.youtube.com/watch?v=tCX0iuGmWnM&list=PLe8jmEHFkvsZL3nLFtkjo9EiA6FUzLtJ9&index=3\",\"variableLive\":true},{\"variableName\":\"play/pause\",\"variableType\":6,\"variableValue\":\"0\",\"variableLive\":true,\"variablePulse\":1091},{\"variableName\":\"volume\",\"variableType\":7,\"variableValue\":\"10\",\"variableLive\":true,\"variableMin\":0,\"variableMax\":100,\"variableStep\":1},{\"variableName\":\"subtitles\",\"variableType\":6,\"variableValue\":\"0\",\"variableLive\":true,\"variablePulse\":69},{\"variableName\":\"playlist_next\",\"variableType\":6,\"variableValue\":\"0\",\"variableLive\":true,\"variablePulse\":545},{\"variableName\":\"playlist_previous\",\"variableType\":6,\"variableValue\":\"0\",\"variableLive\":true,\"variablePulse\":152},{\"variableName\":\"playlist_start_video\",\"variableType\":1,\"variableValue\":\"\",\"variableLive\":true},{\"variableName\":\"playback_speed\",\"variableType\":7,\"variableValue\":\"1\",\"variableLive\":true,\"variableMin\":0.25,\"variableMax\":2,\"variableStep\":0.25},{\"variableName\":\"shuffle\",\"variableType\":6,\"variableValue\":\"0\",\"variableLive\":true,\"variablePulse\":297},{\"variableName\":\"reshuffle\",\"variableType\":2,\"variableValue\":\"false\",\"variableLive\":true},{\"variableName\":\"loop\",\"variableType\":2,\"variableValue\":false,\"variableLive\":true},{\"variableName\":\"refresh_playlist\",\"variableType\":6,\"variableValue\":\"0\",\"variableLive\":true,\"variablePulse\":64}]}",
